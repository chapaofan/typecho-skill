# ============================================
# Typecho 数据库配置
# ============================================
TYPECHO_DB_HOST=localhost
TYPECHO_DB_PORT=3306
TYPECHO_DB_USER=test
TYPECHO_DB_PASSWORD=test
TYPECHO_DB_NAME=typecho
TYPECHO_DB_CHARSET=utf8mb4
# 表前缀（与 config.inc.php 中 $db = new Typecho_Db('Pdo_Mysql', 'typecho_') 一致）
TYPECHO_TABLE_PREFIX=typecho_

# 默认作者（typecho_users.uid），新增文章时会使用该 uid 作为 authorId
TYPECHO_DEFAULT_AUTHOR_ID=1
# 默认分类（typecho_metas.mid, type='category'），新增文章时会使用该 mid 作为默认分类
TYPECHO_DEFAULT_CATEGORY_ID=1

# ============================================
# API Key 鉴权
# ============================================
# 多个 key 用英文逗号分隔。Agent 需在 HTTP Header 中带上： X-API-Key: <key>
API_KEYS=sk-please-change-me-1,sk-please-change-me-2

# 允许来源（防止 CSRF / 简单白名单），多个用逗号分隔，留空表示不限制
ALLOWED_ORIGINS=*

# ============================================
# 腾讯云 COS 配置
# ============================================
# 在 https://console.cloud.tencent.com/cam/capi 申请子账号密钥
COS_SECRET_ID=<your-tencent-cloud-secret-id>
COS_SECRET_KEY=<your-tencent-cloud-secret-key>
COS_REGION=ap-guangzhou
COS_BUCKET=<your-bucket-name-1250000000>
# 访问协议：https | http
COS_SCHEME=https
# 上传目录前缀，例如 blog/
COS_KEY_PREFIX=blog/
# 访问 CDN 域名（可选），为空时使用 COS 默认域名：<Bucket>-<AppId>.cos.<Region>.myqcloud.com
COS_CDN_DOMAIN=

# ============================================
# HTTP 服务
# ============================================
HTTP_HOST=0.0.0.0
HTTP_PORT=8000
HTTP_DEBUG=false
